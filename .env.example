# ───────────── Banco de dados (PostgreSQL self-hosted) ─────────────
# Local (Homebrew): normalmente o usuário é o seu usuário do macOS, sem senha.
DATABASE_URL="postgresql://USER@localhost:5432/hubdemidia?schema=public"

# ───────────── Auth.js (NextAuth) ─────────────
# Gere com: openssl rand -base64 32
AUTH_SECRET=""

# ───────────── Criptografia das chaves BYOK ─────────────
# 32 bytes em hex. Gere com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# ───────────── Multi-tenant ─────────────
# Domínio raiz para resolver subdomínios dos sites (ex.: meusite.localhost:3000).
ROOT_DOMAIN="localhost:3000"

# ───────────── n8n (automação) — opcional ─────────────
# URL do webhook do n8n que o painel chama em eventos (trends.collected, post.published, ...).
N8N_WEBHOOK_URL=""

# E-mail do usuário cujas chaves BYOK a automação usa ao gerar conteúdo via /api/generate.
# Se vazio, usa o primeiro admin.
AUTOMATION_USER_EMAIL=""

# ───────────── Automação (cron/n8n) — opcional ─────────────
# Segredo para autorizar os webhooks POST /api/trends/collect e POST /api/generate
# via header x-cron-secret. Gere com: openssl rand -hex 24
CRON_SECRET=""

# Observação: as chaves de IA (Claude/GPT/Grok) NÃO ficam aqui —
# cada usuário cadastra a própria pelo painel (BYOK), criptografada no banco.
