# HubDeMidia — variáveis de PRODUÇÃO (Easypanel).
# Cole estas chaves no painel do Easypanel (Service → Environment).
# NUNCA versione este arquivo preenchido — só o .example.

# ─────────────────────────── Banco (compose interno) ───────────────────────────
POSTGRES_USER=hubdemidia
POSTGRES_PASSWORD=ALTERE_PARA_UMA_SENHA_FORTE
POSTGRES_DB=hubdemidia

# ─────────────────────────── Auth.js (NextAuth) ───────────────────────────
# Gere com:  openssl rand -base64 32
AUTH_SECRET=

# ─────────────────────────── Criptografia BYOK ───────────────────────────
# 32 bytes em hex. Gere com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ─────────────────────────── Multi-tenant ───────────────────────────
# Domínio raiz do hub — sites ficam em SLUG.ROOT_DOMAIN (curinga).
# Exemplos: hubdemidia.com.br · meudominio.com
ROOT_DOMAIN=

# ─────────────────────────── Automação (opcional) ───────────────────────────
# Segredo p/ autorizar POST /api/trends/collect e POST /api/generate (header x-cron-secret).
# Gere com:  openssl rand -hex 24
CRON_SECRET=

# Webhook de saída — o painel notifica o n8n nos eventos publish/trends/generated.
N8N_WEBHOOK_URL=

# E-mail do usuário cujas chaves BYOK a automação usa em /api/generate (fallback: 1º admin).
AUTOMATION_USER_EMAIL=

# ─────────────────────────── Piloto Automático (interno) ───────────────────────────
# Liga o cron interno que roda o autopilot em todos os sites com a flag ativada.
# AUTOPILOT_ENABLED=true → cron rodando.
# AUTOPILOT_INTERVAL_MINUTES → de quanto em quanto tempo executa (default 120, mínimo 5).
AUTOPILOT_ENABLED=false
AUTOPILOT_INTERVAL_MINUTES=120

# ─────────────────────────── SEO — IndexNow + Google Search Console ───────────────────────────
# IndexNow: avisa Bing/Yandex/Seznam quando publicamos (indexação em segundos).
# Gere com: openssl rand -hex 16
INDEXNOW_KEY=

# Google Search Console: cole o código de verificação meta (apenas o valor).
# Ex.: GSC_VERIFICATION=AbCdEf1234...
GSC_VERIFICATION=
