// HubDeMidia — schema do banco (PostgreSQL)
// Documentação da arquitetura: ../docs/ARQUITETURA.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────── Usuários e acesso (RBAC) ───────────────────────────────

enum Role {
  ADMIN // acesso total: todos os sites, usuários e configurações
  EDITOR // acesso apenas aos sites permitidos (via UserSiteAccess)
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String? // null quando login só via OAuth (futuro)
  role         Role     @default(EDITOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  siteAccess UserSiteAccess[]
  aiKeys     AiKey[]
  accounts   Account[]
  sessions   Session[]
}

// Quais sites cada EDITOR pode acessar. ADMIN ignora esta tabela (vê tudo).
model UserSiteAccess {
  id     String @id @default(cuid())
  userId String
  siteId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([userId, siteId])
}

// ─────────────────────────────── Sites (multi-tenant) ───────────────────────────────

enum SiteStatus {
  DRAFT // em construção
  LIVE // no ar
  PAUSED // pausado
}

model Site {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique // subdomínio/identificador interno
  domain      String?    @unique // domínio customizado (ex.: meusite.com)
  description String?
  status      SiteStatus @default(DRAFT)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // ── Tema/identidade do portal público ──
  primaryColor String? // hex (ex.: #c8102e) — accent do portal
  logoUrl      String?
  tagline      String? // subtítulo curto que aparece no header do portal
  language     String  @default("pt-BR")

  // ── Piloto Automático (autopilot) — gera conteúdo sozinho a cada ciclo ──
  autopilotEnabled           Boolean                @default(false)
  autopilotPostsPerRun       Int                    @default(3) // quantas pautas processar por ciclo
  autopilotFeaturedThreshold Int                    @default(70) // score >= este -> marca destaque
  autopilotProvider          AiProvider             @default(CLAUDE)
  autopilotWithImage         Boolean                @default(true) // gerar imagem ON/OFF (estratégia abaixo)
  autopilotImageStrategy     AutopilotImageStrategy @default(BANK_FIRST)
  autopilotAutoCategory      Boolean                @default(true) // tenta atribuir editoria por keyword

  posts         Post[]
  sources       Source[]
  trends        Trend[]
  pageViews     PageView[]
  access        UserSiteAccess[]
  categories    Category[]
  tags          Tag[]
  autopilotRuns AutopilotRun[]
}

// ─────────────────────────────── Conteúdo ───────────────────────────────

enum PostStatus {
  DRAFT // rascunho (gerado por IA ou manual)
  REVIEW // aguardando revisão humana
  PUBLISHED // publicado
}

model Post {
  id          String     @id @default(cuid())
  siteId      String
  title       String
  slug        String
  content     String // corpo (markdown)
  excerpt     String?
  imageUrl    String? // hero/imagem principal
  heroAlt     String? // alt text da imagem
  status      PostStatus @default(DRAFT)
  seoScore    Int? // score do agente SEO (0-100)
  sourceUrl   String? // notícia de origem, quando aplicável
  createdByAi Boolean    @default(false)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // ── Editoria / curadoria do portal ──
  categoryId     String?
  authorName     String?
  readingMinutes Int? // tempo estimado de leitura (computado em save)
  featured       Boolean @default(false) // marca para destaque na capa

  site      Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  category  Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags      PostTag[]
  pageViews PageView[]

  @@unique([siteId, slug])
  @@index([siteId, status])
  @@index([siteId, status, publishedAt])
  @@index([siteId, categoryId, status])
  @@index([siteId, featured, status])
}

// ─────────────────────────────── Editorias e tags ───────────────────────────────

model Category {
  id          String   @id @default(cuid())
  siteId      String
  name        String
  slug        String
  description String?
  color       String? // hex opcional (badge)
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  site  Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  posts Post[]

  @@unique([siteId, slug])
  @@index([siteId, order])
}

model Tag {
  id     String @id @default(cuid())
  siteId String
  name   String
  slug   String

  site  Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  posts PostTag[]

  @@unique([siteId, slug])
}

model PostTag {
  postId String
  tagId  String
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
}

// ─────────────────────────────── Analytics (first-party, self-host) ───────────────────────────────

// Registro de visualização das páginas públicas dos sites. Agregado sob demanda no painel.
model PageView {
  id        String   @id @default(cuid())
  siteId    String
  postId    String? // quando a visita é de um post específico
  path      String
  referrer  String?
  country   String?
  createdAt DateTime @default(now())

  site Site  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  post Post? @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([siteId, createdAt])
  @@index([postId])
}

// ─────────────────────────────── Monitoramento de tendências ───────────────────────────────

enum SourceType {
  GOOGLE_TRENDS
  RSS
  WEBSITE
}

// Fonte global (siteId null) ou específica de um site.
model Source {
  id        String     @id @default(cuid())
  siteId    String?
  type      SourceType
  url       String
  label     String?
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())

  // ── Filtros / configuração de captação ──
  keywords  String? // CSV de palavras-chave (case-insensitive). Vazio = aceita tudo.
  // Para GOOGLE_TRENDS: códigos do Google Trends (opcional, só ajuda na curadoria).
  geo       String? // ex.: "BR", "US"
  category  String? // ex.: "20" = Esportes; "5" = Computadores e Eletrônicos

  site   Site?   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  trends Trend[]
}

enum TrendStatus {
  NEW // pauta nova, captada
  USED // já virou conteúdo
  DISMISSED // descartada pelo usuário
}

// Pauta captada pelo monitor de tendências (Google Trends / RSS / sites). Alimenta o pipeline de IA.
model Trend {
  id        String      @id @default(cuid())
  siteId    String? // null = global
  sourceId  String? // de qual Source veio (se aplicável)
  title     String
  url       String?
  type      SourceType
  score     Int         @default(0) // sinal "fora da curva" (quanto maior, mais quente)
  status    TrendStatus @default(NEW)
  createdAt DateTime    @default(now())

  site   Site?   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  source Source? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@index([siteId, status, score])
}

// ─────────────────────────────── Piloto Automático (logs de execução) ───────────────────────────────

enum AutopilotStatus {
  RUNNING
  OK
  ERROR
  SKIPPED
}

// Estratégia para a imagem hero dos posts gerados pelo autopilot.
// BANK_FIRST  = tenta Unsplash → Pexels; se nada bater, cai p/ OpenAI (custo mínimo).
// BANK_ONLY   = só banco grátis; sem imagem se não achar (custo ZERO).
// OPENAI_ONLY = sempre gera no OpenAI (mais caro, mas único).
// NONE        = nunca gera imagem.
enum AutopilotImageStrategy {
  BANK_FIRST
  BANK_ONLY
  OPENAI_ONLY
  NONE
}

// Log de cada execução do autopilot — global (siteId null) ou por site.
model AutopilotRun {
  id         String          @id @default(cuid())
  siteId     String?
  startedAt  DateTime        @default(now())
  finishedAt DateTime?
  status     AutopilotStatus @default(RUNNING)
  posted     Int             @default(0)
  errors     Int             @default(0)
  durationMs Int?
  notes      String? // resumo legível p/ humano (curto)

  site Site? @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, startedAt])
  @@index([startedAt])
}

// ─────────────────────────────── IA (BYOK — chaves do usuário) ───────────────────────────────

enum AiProvider {
  CLAUDE
  OPENAI
  GROK
}

// Chave de API do provedor, CRIPTOGRAFADA (ver src/lib/crypto.ts). Nunca em texto puro.
model AiKey {
  id        String     @id @default(cuid())
  userId    String
  provider  AiProvider
  encrypted String // ciphertext da chave de API
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

// ─────────────────────────────── Auth.js (NextAuth) — modelos padrão ───────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}
